DATABASE_URL=CHANGEME_DATABASE_URL
AUTH_SECRET=CHANGEME_AUTH_SECRET
AUTH_GITHUB_ID=CHANGEME_AUTH_GITHUB_ID
AUTH_GITHUB_SECRET=CHANGEME_AUTH_GITHUB_SECRET
ADMIN_EMAIL=admin@example.com
APP_BASE_URL=http://localhost:3000
APP_DISPLAY_NAME="Weekly Client Reports"

# Trigger.dev
TRIGGER_SECRET_KEY=CHANGEME_TRIGGER_SECRET_KEY
TRIGGER_PROJECT_REF=CHANGEME_TRIGGER_PROJECT_REF

# GitHub API token with access to the repositories you report on
GITHUB_PAT=CHANGEME_GITHUB_PAT

# OpenRouter
OPENROUTER_API_KEY=CHANGEME_OPENROUTER_API_KEY
OPENROUTER_MODEL=openai/gpt-5.5

# Vercel Blob
BLOB_READ_WRITE_TOKEN=CHANGEME_BLOB_READ_WRITE_TOKEN

# Report prompt. Prefer NARRATIVE_PROMPT_PATH for private local files.
NARRATIVE_PROMPT=
NARRATIVE_PROMPT_PATH=
REPORT_SENDER_NAME=Team

# Email workflow webhook
N8N_WEBHOOK_URL=CHANGEME_WEBHOOK_URL
N8N_WEBHOOK_SECRET=CHANGEME_WEBHOOK_SECRET

# Telegram bot
TELEGRAM_BOT_TOKEN=CHANGEME_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=CHANGEME_TELEGRAM_CHAT_ID

# Optional seed input
SEED_CLIENTS_PATH=

# Reminder: hours a report must be in 'drafted' status before a nudge is sent (default: 18)
REMINDER_THRESHOLD_HOURS=18
